{
    "name": "block-outside-modification",
    "description": "프로젝트 디렉토리 외부 파일을 수정/삭제하는 Bash 명령(rm, mv, cp, sed -i, > 등)의 실행을 차단하는 훅 (PreToolUse에서 호출)",
    "version": "1.0.0",
    "author": {
        "name": "Changgun Lee",
        "email": "gilchris@estsoft.com"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-outside-modification.sh"
                    }
                ]
            }
        ]
    }
}

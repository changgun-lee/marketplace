{
    "name": "block-git-push",
    "description": "git push 및 원격 저장소에 쓰기를 발생시키는 gh 명령의 실행을 차단하는 훅 (PreToolUse에서 호출)",
    "version": "1.0.0",
    "author": {
        "name": "Changgun Lee",
        "email": "gilchris@estsoft.com"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-git-push.sh"
                    }
                ]
            }
        ]
    }
}
